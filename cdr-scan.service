[Unit]
Description=CDR Scan static server
After=network.target

[Service]
Type=simple
User=egarcia
WorkingDirectory=/home/egarcia/cdr-scan
Environment=HOST=127.0.0.1
Environment=PORT=8089
ExecStart=/usr/bin/node /home/egarcia/cdr-scan/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
